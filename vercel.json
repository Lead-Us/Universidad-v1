{
  "framework": "vite",
  "functions": {
    "api/aprender-chat.js": { "maxDuration": 300 }
  },
  "rewrites": [
    { "source": "/", "destination": "/landing/index.html" },
    { "source": "/((?!api/|landing/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/instagram-cron",
      "schedule": "0 12 * * *"
    }
  ]
}
