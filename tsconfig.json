{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist-ts",
    "rootDir": "."
  },
  "include": ["src/prompts", "src/chat", "scripts"],
  "exclude": ["node_modules", "dist", "src/components", "src/pages", "src/hooks", "src/lib", "src/services"]
}
