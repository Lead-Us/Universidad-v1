# ─── Agente Instagram @universidadv1 ───────────────────────────────────────────
# Copia este archivo a .env y completa los valores

# Anthropic (Claude) — OBLIGATORIO
# Consíguelo en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Instagram Graph API — para `node run.js track` (métricas reales)
# Copia desde .env.local del proyecto principal (universidadv1/)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# ─── OPCIONALES ────────────────────────────────────────────────────────────────

# Brave Search API — 2000 búsquedas/mes gratis, mejora el scraping de tendencias
# Consíguelo en: https://api.search.brave.com/ (Free Data plan)
# Sin esto, el agente igual funciona usando solo Reddit (100% gratis)
BRAVE_API_KEY=

# ─── El scraping de Reddit es 100% gratis, sin key, sin cuenta ────────────────
