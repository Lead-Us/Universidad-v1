{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/ernestoah/Documents/Antigravity/universidadv1 && npm run lint --silent 2>&1 | head -50"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/ernestoah/Documents/Antigravity/universidadv1/.claude/hooks/check-env-staged.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run lint*)",
      "Bash(npm run build*)",
      "Bash(npm run dev*)",
      "Bash(npm run preview*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add src/*)",
      "Bash(git add .claude/*)",
      "Bash(git add supabase/*)",
      "Bash(git add api/*)",
      "Bash(git add docs/*)",
      "Bash(git commit*)",
      "Bash(git stash*)",
      "Bash(git worktree*)",
      "mcp__puppeteer__*",
      "mcp__ide__getDiagnostics"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)"
    ]
  }
}
